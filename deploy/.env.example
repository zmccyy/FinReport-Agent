# FinReport Agent — 环境变量模板
# 复制为 .env 并根据需要修改
# 版本：v1.0

# === MySQL ===
MYSQL_ROOT_PASSWORD=finreport
MYSQL_DATABASE=finreport
MYSQL_USER=finreport
MYSQL_PASSWORD=finreport
MYSQL_PORT=3306

# === Redis ===
REDIS_PORT=6379
# REDIS_PASSWORD=    # 开发环境留空

# === RabbitMQ ===
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# === MinIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# === Milvus ===
MILVUS_PORT=19530
MILVUS_METRIC_PORT=9091

# === Application ===
BACKEND_PORT=8080
AI_SERVICE_PORT=8000
FRONTEND_PORT=80

# === Model Weights (host path) ===
# MODELS_DIR=./models
